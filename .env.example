# ==============================================================================
# NightFlow - 클럽 테이블 경매 플랫폼 환경변수 설정
# ==============================================================================
# IMPORTANT: 이 파일은 템플릿입니다. 실제 값은 .env.local에 설정하세요!
# .env.local은 절대 git에 커밋하지 마세요!

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# Supabase 프로젝트 URL (예: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-project.supabase.co

# Supabase Anon Key (공개 키, 브라우저에서 사용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (비공개, 서버 사이드만 사용)
# ⚠️ 주의: 이 키는 RLS를 우회합니다. 절대 브라우저에 노출하지 마세요!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# Kakao OAuth
# ------------------------------------------------------------------------------
# Kakao 개발자 센터에서 발급받은 REST API 키
NEXT_PUBLIC_KAKAO_CLIENT_ID=your-kakao-client-id

# Kakao OAuth 시크릿 (필요시)
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ------------------------------------------------------------------------------
# Naver Maps Configuration (클럽 위치 등록용)
# ------------------------------------------------------------------------------
# Naver Maps API Client ID (공개 키, 브라우저에서 사용)
# 발급 방법: https://developers.naver.com/apps > 애플리케이션 등록 > 지도 API
# 주소 검색과 좌표 변환(지오코딩)에 사용됩니다.
NEXT_PUBLIC_NAVER_CLIENT_ID=your-naver-client-id-here

# Naver Maps API Client Secret (비공개, 서버 사이드 전용)
# ⚠️ 주의: NEXT_PUBLIC_ 접두사 없음! 서버에서만 사용됩니다.
NAVER_CLIENT_SECRET=your-naver-client-secret-here

# ------------------------------------------------------------------------------
# Coolsms (SMS 문자 발송) Configuration
# ------------------------------------------------------------------------------
# Coolsms API 키 (https://www.coolsms.co.kr에서 발급)
# Edge Function에서 사용 (Supabase Secrets로 관리 권장)
# 발급 방법: Coolsms 로그인 > 개발자센터 > API Key 관리
COOLSMS_API_KEY=your-coolsms-api-key-here
COOLSMS_API_SECRET=your-coolsms-api-secret-here

# 발신번호 (Coolsms에서 등록/승인받은 번호, 하이픈 없이)
# 예: 01012345678
COOLSMS_SENDER=01012345678

# ------------------------------------------------------------------------------
# SOLAPI (카카오 알림톡) Configuration
# ------------------------------------------------------------------------------
# SOLAPI API 키 (https://console.solapi.com에서 발급)
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret

# 발신번호 (SOLAPI에서 등록한 번호, 010XXXXXXXX 형식)
SOLAPI_SENDER_NUMBER=01012345678

# 카카오 비즈니스 채널 ID (카카오톡 채널 관리자센터에서 확인)
SOLAPI_PFID=your-kakao-channel-pfid

# 알림톡 템플릿 ID (카카오 승인 후 SOLAPI 대시보드에서 확인)
ALIMTALK_TPL_AUCTION_STARTED=template-id-placeholder
ALIMTALK_TPL_AUCTION_WON=template-id-placeholder
ALIMTALK_TPL_OUTBID=template-id-placeholder
ALIMTALK_TPL_CLOSING_SOON=template-id-placeholder
ALIMTALK_TPL_VISIT_CONFIRMED=template-id-placeholder
ALIMTALK_TPL_NOSHOW_BANNED=template-id-placeholder
ALIMTALK_TPL_CONTACT_DEADLINE_WARNING=template-id-placeholder
ALIMTALK_TPL_FALLBACK_WON=template-id-placeholder
ALIMTALK_TPL_EARLYBIRD_DDAY_REMINDER=template-id-placeholder

# 퍼즐 알림톡 템플릿 (카카오 심사 후 SOLAPI 대시보드에서 확인)
ALIMTALK_TPL_PUZZLE_FIRST_OFFER=template-id-placeholder
ALIMTALK_TPL_PUZZLE_DEADLINE_REMINDER=template-id-placeholder
ALIMTALK_TPL_PUZZLE_LEADER_CHANGED=template-id-placeholder
ALIMTALK_TPL_PUZZLE_MATCHED=template-id-placeholder
ALIMTALK_TPL_PUZZLE_OFFER_WON=template-id-placeholder

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
# 애플리케이션 기본 URL
# 로컬: http://localhost:3000
# 프로덕션: https://nightflow.co (예시)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 애플리케이션 이름
NEXT_PUBLIC_APP_NAME=NightFlow

# ------------------------------------------------------------------------------
# Monitoring & Analytics
# ------------------------------------------------------------------------------
# Sentry DSN (에러 추적)
# Sentry 프로젝트에서 발급 (https://sentry.io)
# 예: https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn-here

# Google Analytics 4 측정 ID
# Google Analytics 관리 > 데이터 스트림에서 확인 (G-XXXXXXXXXX 형식)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Mixpanel 프로젝트 토큰
# Mixpanel > Settings > Project Token에서 확인
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-token

# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------
# 개발 환경 설정 (선택사항)
# ------------------------------------------------------------------------------
# 로그 레벨 (development, production)
NODE_ENV=development

# ==============================================================================
# 주의사항
# ==============================================================================
# 1. .env.example: git에 커밋 (템플릿)
# 2. .env.local: git에 커밋 금지 (실제 키 저장)
# 3. 프로덕션 배포 시 모든 테스트 키를 실제 키로 교체하세요!
# 4. NEXT_PUBLIC_* 접두사는 브라우저에 노출됩니다 (민감한 키 사용 금지)
# ==============================================================================

# 테스트 환경 휴대폰 인증 스킵 (프로덕션은 반드시 false 또는 미설정)
NEXT_PUBLIC_SKIP_PHONE_VERIFICATION=false
